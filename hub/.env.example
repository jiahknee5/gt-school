# GT Marketing Hub — environment template.
# Copy to .env.local and fill with YOUR OWN free-tier keys. .env.local is gitignored.
# NEVER commit real secrets. How credentials are managed is explicitly evaluated.

# --- Supabase (Postgres + Auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER used on program-scoped paths (service_role bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection for the app_rw path (via the Supavisor pooler).
# This is the RESTRICTED login role (NOSUPERUSER, NOBYPASSRLS) — NOT service_role.
APP_RW_DATABASE_URL=

# --- HubSpot (CRM = source of truth for contacts/deals) ---
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_APP_SECRET=                 # for X-HubSpot-Signature-v3 validation
HUBSPOT_PORTAL_ID=

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# --- Open Data (tryopendata.ai) — Texas public-school data ---
OPENDATA_API_BASE=https://api.tryopendata.ai
OPENDATA_API_KEY=                   # if the free tier requires one

# --- Anthropic (Ask-the-Hub agent + Status verdict generation) ---
ANTHROPIC_API_KEY=
ASK_THE_HUB_MODEL=claude-opus-4-8
# Model used by the weekly Status verdict generator. Falls back to ASK_THE_HUB_MODEL.
# With no ANTHROPIC_API_KEY the Status pipeline uses the DETERMINISTIC rubric generator.
STATUS_GEN_MODEL=claude-opus-4-8
# Set to "false" to force the deterministic generator even when a key is present.
STATUS_GEN_LIVE=

# --- Status snapshots (weekly executive verdict, pre-loaded) ---
# Secret that authorizes the Vercel Cron route /api/cron/status-refresh. Vercel sends it
# as `Authorization: Bearer <CRON_SECRET>` automatically when set. REQUIRED in production
# for scheduled refresh. Generate with: openssl rand -hex 32  — NEVER commit the real value.
CRON_SECRET=
# Where the file-based snapshot fallback reads/writes when no APP_RW_DATABASE_URL is set.
# Defaults to an OS tmp dir (ephemeral on Vercel). The page still works without it because
# missing weeks are generated deterministically on view.
STATUS_SNAPSHOT_DIR=
# NOTE: Vercel Cron schedules run in UTC (no timezone field). vercel.json uses
# "0 7 * * 1" (07:00 UTC Mon). For 07:00 America/Chicago use "0 12 * * 1" (CDT).

# --- App config ---
PROGRAMS=summer_camp,fall_enrollment
PARITY_THRESHOLD=0.95
INBOUND_HUBSPOT_DEMO=manual         # manual reconcile trigger | ngrok tunnel

# --- Auth / RBAC (Tier 0) ---
# Secret used to HMAC-sign the session cookie. REQUIRED in production (>=16 chars).
# Generate one with: openssl rand -hex 32   — and NEVER commit the real value.
AUTH_SECRET=
# Dev auth mode: password-less Admin/Leader/Operator role switcher that still mints a
# real, server-enforced session cookie. Defaults ON outside production. Set to "false"
# (and wire a real IdP) for any real deployment. When on without AUTH_SECRET, a known
# insecure dev secret is used so the app runs out-of-the-box locally.
AUTH_DEV_MODE=true
