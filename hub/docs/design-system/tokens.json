{
  "$meta": {
    "name": "GT School Design System Tokens",
    "source": "https://gt.school (redirects to https://www.gt.school)",
    "platform": "Webflow",
    "extractedOn": "2026-06-26",
    "method": "Real computed values + :root custom properties extracted from the rendered site via headless Chromium (agent-browser eval). Nothing here is invented; values approximated from pixels are flagged in DESIGN-SYSTEM.md.",
    "note": "Original Webflow variable names are preserved in tokens.css comments. rem values assume a 16px root (1rem = 16px)."
  },
  "color": {
    "brand": {
      "orange":        { "value": "#e48b53", "note": "Primary accent. The atom logo mark, highlighted nav item, link/CTA accents." },
      "navy":          { "value": "#002a3a", "note": "Primary dark. Solid button background, dark section background." },
      "navyDark":      { "value": "#001117", "note": "Darkest. Primary body text and footer background." },
      "blue":          { "value": "#004f71" },
      "blueDark":      { "value": "#003b5c" },
      "goldLightest":  { "value": "#f8e8de" },
      "goldLighter":   { "value": "#f5ddcd" },
      "goldLight":     { "value": "#ebba9b" },
      "yellowDarker":  { "value": "#5e5515", "note": "Warning text." }
    },
    "neutral": {
      "white":      { "value": "#ffffff" },
      "offWhite":   { "value": "#fcf4ef", "note": "Warm off-white. Secondary section background." },
      "greyLight":  { "value": "#d9d9d9", "note": "Default border color." },
      "grey":       { "value": "#cac6c4", "note": "Secondary button border." },
      "greyDark":   { "value": "#5b5b5b", "note": "Secondary / muted text." },
      "transparent":{ "value": "transparent" }
    },
    "semantic": {
      "background": {
        "primary":   { "value": "#ffffff" },
        "secondary": { "value": "#fcf4ef" },
        "tertiary":  { "value": "#002a3a" }
      },
      "text": {
        "primary":   { "value": "#001117" },
        "secondary": { "value": "#5b5b5b" },
        "alternate": { "value": "#ffffff", "note": "Text on dark backgrounds." }
      },
      "border": {
        "primary": { "value": "#d9d9d9" }
      },
      "state": {
        "successBackground": { "value": "#f5ddcd" },
        "successText":       { "value": "#f8e8de" },
        "warningBackground": { "value": "#fcf4ef" },
        "warningText":       { "value": "#5e5515" }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "heading": { "value": "Literata, Georgia, sans-serif", "note": "Serif used as the display face. Self-hosted Literata (Light/Regular/Medium/Italic .ttf)." },
      "body":    { "value": "\"Inter Tight\", Arial, sans-serif", "note": "Self-hosted Inter Tight (Light/Regular/Medium/Bold .ttf)." },
      "utility": { "value": "Inconsolata, Arial, sans-serif", "note": "Monospace used for uppercase buttons and labels. Self-hosted Inconsolata + Google Fonts (Inconsolata:400,700)." }
    },
    "fontWeight": {
      "thin": 100,
      "xlight": 200,
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semiBold": 600,
      "bold": 700,
      "xbold": 800,
      "black": 900
    },
    "fontSize": {
      "tiny":    { "value": "0.875rem", "px": 14 },
      "small":   { "value": "1rem",     "px": 16 },
      "regular": { "value": "1.125rem", "px": 18 },
      "medium":  { "value": "1.25rem",  "px": 20 },
      "large":   { "value": "1.5rem",   "px": 24 },
      "xlarge":  { "value": "2rem",     "px": 32 }
    },
    "lineHeight": {
      "small":  1.15,
      "medium": 1.25,
      "large":  1.3
    },
    "letterSpacing": {
      "tight":   "-0.1rem",
      "default": "0rem"
    },
    "heading": {
      "h1": { "fontSize": "3.25rem", "px": 52, "lineHeight": 1.15, "fontWeight": 300, "letterSpacing": "-0.1rem" },
      "h2": { "fontSize": "3rem",    "px": 48, "lineHeight": 1.15, "fontWeight": 300, "letterSpacing": "0rem" },
      "h3": { "fontSize": "2rem",    "px": 32, "lineHeight": 1.15, "fontWeight": 300, "letterSpacing": "0rem" },
      "h4": { "fontSize": "1.5rem",  "px": 24, "lineHeight": 1.25, "fontWeight": 400, "letterSpacing": "0rem" },
      "h5": { "fontSize": "1.25rem", "px": 20, "lineHeight": 1.25, "fontWeight": 400, "letterSpacing": "0rem" },
      "h6": { "fontSize": "0.875rem","px": 14, "lineHeight": 1.25, "fontWeight": 500, "letterSpacing": "0rem" }
    },
    "body": { "fontSize": "1rem", "px": 16, "lineHeight": 1.3, "fontWeight": 400, "letterSpacing": "0rem" }
  },
  "spacing": {
    "none":    "0rem",
    "tiny":    "0.125rem",
    "xxsmall": "0.25rem",
    "xsmall":  "0.5rem",
    "small":   "0.75rem",
    "regular": "1rem",
    "medium":  "1.5rem",
    "large":   "2rem",
    "xlarge":  "3rem",
    "xxlarge": "4rem",
    "huge":    "5rem",
    "xhuge":   "6rem",
    "xxhuge":  "8rem",
    "globalPadding": "2.5rem",
    "gap": { "small": "0.75rem", "medium": "1.5rem" },
    "sectionPadding": { "small": "3rem", "medium": "5rem", "large": "8rem" }
  },
  "size": {
    "container": { "small": "48rem", "medium": "64rem", "large": "90rem" },
    "maxWidth": {
      "xxsmall": "12rem",
      "xsmall":  "16rem",
      "small":   "20rem",
      "medium":  "32rem",
      "large":   "48rem",
      "xlarge":  "64rem",
      "xxlarge": "80rem"
    }
  },
  "borderRadius": {
    "small":  { "value": "0.25rem", "px": 4 },
    "medium": { "value": "0.5rem",  "px": 8,  "note": "Buttons." },
    "large":  { "value": "0.75rem", "px": 12 }
  },
  "borderWidth": {
    "regular": "1px"
  },
  "shadow": {
    "sm": { "value": "1px 2px 14px 0px rgba(0, 0, 0, 0.03)", "note": "Only box-shadow found on the page; used on cards/elevated surfaces." }
  },
  "transition": {
    "duration": { "default": "0.2s" },
    "easing":   { "default": "ease", "note": "No custom cubic-bezier found; the page relies on the browser default ease over 0.2s." },
    "examples": ["color 0.2s", "background-color 0.2s", "all 0.2s"]
  },
  "breakpoints": {
    "$note": "Standard Webflow breakpoints (max-width). gt.school does not define custom breakpoints; these are the platform defaults the layout is built against.",
    "desktop":     "(min-width: 992px)",
    "tablet":      "(max-width: 991px)",
    "mobileLandscape": "(max-width: 767px)",
    "mobilePortrait":  "(max-width: 479px)"
  },
  "component": {
    "buttonPrimary": {
      "background": "#002a3a",
      "color": "#ffffff",
      "fontFamily": "Inconsolata, Arial, sans-serif",
      "fontSize": "1rem",
      "fontWeight": 500,
      "textTransform": "uppercase",
      "padding": "8px 16px",
      "borderRadius": "8px",
      "border": "none",
      "transition": "all 0.2s"
    },
    "buttonSecondary": {
      "background": "transparent",
      "color": "#002a3a",
      "fontFamily": "Inconsolata, Arial, sans-serif",
      "fontSize": "1rem",
      "fontWeight": 500,
      "textTransform": "uppercase",
      "padding": "8px 16px",
      "borderRadius": "8px",
      "border": "1px solid #cac6c4",
      "transition": "color 0.2s"
    },
    "nav": {
      "background": "#ffffff",
      "fontFamily": "\"Inter Tight\", Arial, sans-serif",
      "fontSize": "0.875rem",
      "fontWeight": 500,
      "linkColor": "#001117",
      "highlightColor": "#e48b53"
    }
  }
}
